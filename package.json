{
  "name": "nhi-archive",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.mjs",
    "dev:full": "npm-run-all --parallel server dev",
    "ingest:wikipedia": "node scripts/pipeline/fetch-wikipedia-ufo-data.mjs",
    "ingest:global": "node scripts/pipeline/fetch-global-ufo-data.mjs",
    "ingest": "node scripts/pipeline/run.mjs",
    "canonicalize": "node scripts/pipeline/canonicalize-dupes.mjs",
    "build:client-artifacts": "node scripts/pipeline/build-client-artifacts.mjs",
    "build:sqlite": "node scripts/pipeline/build-sqlite.mjs && node scripts/pipeline/detect-communities.mjs && node scripts/pipeline/register-perspectives.mjs",
    "refresh:data": "npm run ingest:wikipedia && npm run ingest:global && npm run ingest && npm run canonicalize && npm run build:client-artifacts && npm run build:sqlite",
    "build": "npm run ingest && npm run canonicalize && npm run build:client-artifacts && npm run build:sqlite && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "better-sqlite3": "^12.9.0",
    "csv-parse": "^6.2.1",
    "d3-geo": "^3.1.1",
    "fastify": "^5.8.5",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "minisearch": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "topojson-client": "^3.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
